choice Slot {
    some: ref<i32>,
    none,
}

fun leak() -> ref<i32> {
    let local = 1
    let slot: Slot = Slot.some(&local)
    match slot {
        .some => borrowed {
            return borrowed
        }
        .none {
            return &local
        }
    }
}

pub fun main() -> Void {
    let _borrowed = leak()
}
