fn clear(view: MutSpan<Maybe<u8>>) -> Void {
    view[0] = null
}

pub fn main() -> Void {
    let input: [1]u8 = [1]
    var values: [1]Maybe<u8> = [std.mem.get(input, 0)]
    let view: MutSpan<Maybe<u8>> = values
    if view[0].has {
        if true {
            var values: [1]Maybe<u8> = [null]
            clear(view)
        }
        let byte: u8 = view[0].value
    }
}
