shape Box {
    value: ref<i32>,
}

shape Holder {
    box: Box,
}

fun storeLocal(holder: mutref<Holder>) -> Void {
    let local = 1
    holder.box = Box { value: &local }
}

pub fun main() -> Void {
    let fallback = 0
    let mut holder = Holder { box: Box { value: &fallback } }
    storeLocal(&mut holder)
}
