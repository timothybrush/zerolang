pub fn main(world: World) -> Void raises {
    let text: Span<u8> = "alpha\nzero beta\r\nzero gamma"
    var output: [16]u8 = [0_u8; 16]
    var offset: usize = 0
    let wrote_a: Maybe<usize> = std.io.writeByte(output, offset, 111_u8)
    if wrote_a.has {
        offset = wrote_a.value
    }
    let wrote_tail: Maybe<usize> = std.io.writeSpan(output, offset, "k")
    if wrote_tail.has {
        offset = wrote_tail.value
    }
    let first: Maybe<Span<u8>> = std.io.nextLine(text, 0)
    let second_start: usize = std.io.nextLineStart(text, 0)
    let second: Maybe<Span<u8>> = std.io.nextLine(text, second_start)
    let third_start: usize = std.io.nextLineStart(text, second_start)
    let third: Maybe<Span<u8>> = std.io.nextLine(text, third_start)
    let written: Span<u8> = std.io.written(output, offset)
    if first.has && second.has && third.has && std.io.countLines(text) == 3 && std.io.remaining(output, offset) == 14 && std.mem.eql(written, "ok") && std.mem.eql(second.value, "zero beta") && std.str.contains(third.value, "gamma") {
        check world.out.write("std io lines ok\n")
    }
}
