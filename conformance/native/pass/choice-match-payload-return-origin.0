choice Slot {
    some: ref<i32>,
    none,
}

fun get(slot: Slot, fallback: ref<i32>) -> ref<i32> {
    match slot {
        .some => borrowed {
            return borrowed
        }
        .none {
            return fallback
        }
    }
}

pub fun main() -> Void {
    let value = 1
    let slot: Slot = Slot.some(&value)
    let _borrowed = get(slot, &value)
}
