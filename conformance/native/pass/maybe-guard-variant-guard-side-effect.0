choice Flag {
    yes,
    no,
}

type Holder {
    value: Maybe<u8>,
}

fn clear(holder: mutref<Holder>) -> Bool {
    holder.value = null
    return true
}

fn read(flag: Flag) -> u8 {
    let input: [1]u8 = [1]
    var holder: Holder = Holder { value: std.mem.get(input, 0) }
    if holder.value.has {
        match flag {
            .yes if clear(&mut holder) {
                return 0_u8
            }
            .yes {
                return 0_u8
            }
            .no {
                return holder.value.value
            }
        }
    }
    return 0_u8
}

pub fn main() -> Void {
    let byte: u8 = read(Flag.no)
}
