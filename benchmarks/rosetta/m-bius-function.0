fn mobius i32 n u32
  mut value n
  mut primes u32 0
  mut p u32 2
  while <= (* p p) value
    if == (% value p) 0
      set value / value p
      set primes + primes 1
      if == (% value p) 0
        ret 0
    set p + p 1
  if > value 1
    set primes + primes 1
  if == (% primes 2) 0
    ret 1
  ret - 0 1

pub fn main Void world World !
  if == (mobius 30) (- 0 1)
    check world.out.write "mobius ok\n"
