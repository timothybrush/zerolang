fn firstRun usize text Span<u8>
  if == (std.mem.len text) 0
    ret 0
  mut i usize 1
  while < i (std.mem.len text)
    if != text[i] text[0]
      ret i
    set i + i 1
  ret std.mem.len text

pub fn main Void world World !
  if == (firstRun (std.mem.span "aaabb")) 3
    check world.out.write "run length ok\n"
