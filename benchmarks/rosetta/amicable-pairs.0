fn properDivisorSum u32 n u32
  mut sum u32 0
  mut d u32 1
  while < d n
    if == (% n d) 0
      set sum + sum d
    set d + d 1
  ret sum

fn amicable Bool a u32 b u32
  ret && (== (properDivisorSum a) b) (== (properDivisorSum b) a)

pub fn main Void world World !
  if amicable 220 284
    check world.out.write "amicable ok\n"
