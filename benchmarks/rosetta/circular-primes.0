fn prime Bool n u32
  if < n 2
    ret false
  mut d u32 2
  while <= (* d d) n
    if == (% n d) 0
      ret false
    set d + d 1
  ret true

fn rotate3 u32 n u32
  ret + (* (% n 100) 10) (/ n 100)

fn circularPrime3 Bool n u32
  let a rotate3 n
  let b rotate3 a
  ret && (&& (prime n) (prime a)) (prime b)

pub fn main Void world World !
  if circularPrime3 197
    check world.out.write "circular prime ok\n"
