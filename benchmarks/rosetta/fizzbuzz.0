fn fizzScore u32 n u32
  mut i u32 1
  mut score u32 0
  while <= i n
    if == (% i 15) 0
      set score + score 3
    else
      if == (% i 3) 0
        set score + score 1
      else
        if == (% i 5) 0
          set score + score 2
    set i + i 1
  ret score

pub fn main Void world World !
  if == (fizzScore 15) 11
    check world.out.write "fizzbuzz ok\n"
