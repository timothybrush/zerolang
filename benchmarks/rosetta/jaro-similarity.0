fn samePositions u32 left Span<u8> right Span<u8>
  mut count u32 0
  mut i usize 0
  while < i (std.mem.len left)
    if == left[i] right[i]
      set count + count 1
    set i + i 1
  ret count

pub fn main Void world World !
  if == (samePositions (std.mem.span "MARTHA") (std.mem.span "MARHTA")) 4
    check world.out.write "jaro similarity ok\n"
