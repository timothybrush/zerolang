fn countByte u32 text Span<u8> needle u8
  mut count u32 0
  mut i usize 0
  while < i (std.mem.len text)
    if == text[i] needle
      set count + count 1
    set i + i 1
  ret count

pub fn main Void world World !
  if == (countByte (std.mem.span "banana") 97) 3
    check world.out.write "substring occurrences ok\n"
