fn pow10 u32 exp u32
  mut result u32 1
  mut i u32 0
  while < i exp
    set result * result 10
    set i + i 1
  ret result

fn digitCount u32 n0 u32
  mut n n0
  mut count u32 0
  while > n 0
    set count + count 1
    set n / n 10
  ret count

fn cyclops Bool n u32
  let count digitCount n
  if == (% count 2) 0
    ret false
  let mid / count 2
  if != (% (/ n (pow10 mid)) 10) 0
    ret false
  mut value n
  mut pos u32 0
  while < pos count
    let digit % value 10
    if && (!= pos mid) (== digit 0)
      ret false
    set value / value 10
    set pos + pos 1
  ret true

pub fn main Void world World !
  if && (cyclops 105) (== (cyclops 100) false)
    check world.out.write "cyclops ok\n"
