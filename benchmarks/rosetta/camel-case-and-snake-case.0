fn underscoreCount u32 text Span<u8>
  mut count u32 0
  mut i usize 0
  while < i (std.mem.len text)
    if == text[i] 95
      set count + count 1
    set i + i 1
  ret count

pub fn main Void world World !
  if == (underscoreCount (std.mem.span "camel_case_word")) 2
    check world.out.write "camel snake ok\n"
