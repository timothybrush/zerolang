fn numberAfterA u32 text Span<u8>
  mut value u32 0
  mut i usize 1
  while < i (std.mem.len text)
    set value + (* value 10) ((- text[i] 48) as u32)
    set i + i 1
  ret value

pub fn main Void world World !
  if < (numberAfterA (std.mem.span "a2")) (numberAfterA (std.mem.span "a10"))
    check world.out.write "natural sort ok\n"
