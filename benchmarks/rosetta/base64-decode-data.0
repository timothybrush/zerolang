fn b64 u8 c u8
  if && (>= c 65) (<= c 90)
    ret - c 65
  if && (>= c 97) (<= c 122)
    ret + (- c 97) 26
  if && (>= c 48) (<= c 57)
    ret + (- c 48) 52
  if == c 43
    ret 62
  ret 63

fn firstByte u8 a u8 b u8
  ret + (* (b64 a) 4) (/ (b64 b) 16)

pub fn main Void world World !
  if == (firstByte 84 87) 77
    check world.out.write "base64 decode ok\n"
