fn choose u32 n u32 k0 u32
  mut k k0
  if > k (- n k)
    set k - n k
  mut result u32 1
  mut i u32 1
  while <= i k
    set result / (* result (+ (- n k) i)) i
    set i + i 1
  ret result

fn permute u32 n u32 k u32
  mut result u32 1
  mut i u32 0
  while < i k
    set result * result (- n i)
    set i + i 1
  ret result

pub fn main Void world World !
  if && (== (choose 5 3) 10) (== (permute 5 3) 60)
    check world.out.write "combinations permutations ok\n"
