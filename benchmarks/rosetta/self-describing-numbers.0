fn countDigit u32 n0 u32 digit u32
  mut n n0
  mut count u32 0
  while > n 0
    if == (% n 10) digit
      set count + count 1
    set n / n 10
  ret count

fn selfDescribe Bool n u32
  let d0 / n 1000
  let d1 % (/ n 100) 10
  let d2 % (/ n 10) 10
  let d3 % n 10
  ret && (&& (== (countDigit n 0) d0) (== (countDigit n 1) d1)) (&& (== (countDigit n 2) d2) (== (countDigit n 3) d3))

pub fn main Void world World !
  if selfDescribe 2020
    check world.out.write "self describing ok\n"
