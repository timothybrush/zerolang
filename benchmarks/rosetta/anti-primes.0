fn divisorCount u32 n u32
  mut count u32 0
  mut d u32 1
  while <= d n
    if == (% n d) 0
      set count + count 1
    set d + d 1
  ret count

fn antiPrime Bool n u32
  let target divisorCount n
  mut value u32 1
  while < value n
    if >= (divisorCount value) target
      ret false
    set value + value 1
  ret true

pub fn main Void world World !
  if antiPrime 12
    check world.out.write "anti prime ok\n"
