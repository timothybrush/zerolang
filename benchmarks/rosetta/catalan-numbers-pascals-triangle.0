fn binomial u32 n u32 k0 u32
  mut k k0
  if > k (- n k)
    set k - n k
  mut result u32 1
  mut i u32 1
  while <= i k
    set result / (* result (+ (- n k) i)) i
    set i + i 1
  ret result

fn catalan u32 n u32
  ret / (binomial (* 2 n) n) (+ n 1)

pub fn main Void world World !
  if == (catalan 5) 42
    check world.out.write "catalan ok\n"
