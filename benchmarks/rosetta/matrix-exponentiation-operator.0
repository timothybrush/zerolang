pub fn main Void world World !
  let matrix [4]u32 [1, 1, 1, 0]
  mut square [4]u32 [0;4]
  set square[0] + (* matrix[0] matrix[0]) (* matrix[1] matrix[2])
  set square[1] + (* matrix[0] matrix[1]) (* matrix[1] matrix[3])
  set square[2] + (* matrix[2] matrix[0]) (* matrix[3] matrix[2])
  set square[3] + (* matrix[2] matrix[1]) (* matrix[3] matrix[3])
  if && (== square[0] 2) (== square[3] 1)
    check world.out.write "matrix exponent ok\n"
