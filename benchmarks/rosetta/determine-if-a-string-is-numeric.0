fn numeric Bool text Span<u8>
  if == (std.mem.len text) 0
    ret false
  mut i usize 0
  while < i (std.mem.len text)
    if || (< text[i] 48) (> text[i] 57)
      ret false
    set i + i 1
  ret true

pub fn main Void world World !
  if && (numeric (std.mem.span "12345")) (== (numeric (std.mem.span "12a")) false)
    check world.out.write "numeric string ok\n"
