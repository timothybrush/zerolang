fn firstOctet u32 text Span<u8>
  mut value u32 0
  mut i usize 0
  while < i (std.mem.len text)
    if == text[i] 46
      ret value
    set value + (* value 10) ((- text[i] 48) as u32)
    set i + i 1
  ret value

pub fn main Void world World !
  if == (firstOctet (std.mem.span "127.0.0.1")) 127
    check world.out.write "parse ip ok\n"
