fn distance1 u32 left Span<u8> right Span<u8>
  mut edits u32 0
  mut i usize 0
  while < i (std.mem.len left)
    if != left[i] right[i]
      set edits + edits 1
    set i + i 1
  ret edits

pub fn main Void world World !
  if == (distance1 (std.mem.span "kitten") (std.mem.span "sitten")) 1
    check world.out.write "levenshtein ok\n"
