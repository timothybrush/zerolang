fn base58 Bool c u8
  if && (>= c 49) (<= c 57)
    ret != c 48
  if && (>= c 65) (<= c 90)
    ret && (!= c 73) (!= c 79)
  if && (>= c 97) (<= c 122)
    ret != c 108
  ret false

pub fn main Void world World !
  if && (base58 49) (== (base58 48) false)
    check world.out.write "bitcoin address ok\n"
